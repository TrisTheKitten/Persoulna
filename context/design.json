{
    "theme": {
        "name": "Persoulna",
        "aesthetic": "modern-organic-mobile",
        "emotional_feel": "friendly, creative, structured, premium",
        "target_audience": "mobile-first users, creators, AI enthusiasts",
        "keywords": [
            "conversational",
            "organic shapes",
            "soft gradients",
            "rounded geometry",
            "warm minimalist"
        ],
        "description": "A design system combining the structured, highly rounded, and floating conversational UI of a modern mobile assistant with a rich, warm color palette of deep teal, terracotta, dusty rose, and royal blue.",
        "mode": "light"
    },
    "colors": {
        "brand": {
            "primary": "#116A5A",
            "secondary": "#D06E55",
            "tertiary": "#2E4A9E"
        },
        "neutral": {
            "50": "#FAF6F5",
            "100": "#F5ECE9",
            "200": "#E5C9C8",
            "300": "#D9C3C0",
            "400": "#A8928F",
            "500": "#7D6B69",
            "600": "#5C4E4C",
            "700": "#403534",
            "800": "#261F1E",
            "900": "#140F0F"
        },
        "semantic": {
            "success": "#10B981",
            "warning": "#F59E0B",
            "error": "#EF4444",
            "info": "#2E4A9E"
        },
        "background": {
            "default": "#FAF6F5",
            "paper": "#FFFFFF",
            "elevated": "#FFFFFF",
            "inverse": "#116A5A"
        },
        "text": {
            "primary": "#140F0F",
            "secondary": "#5C4E4C",
            "disabled": "#A8928F",
            "inverse": "#FFFFFF"
        },
        "border": {
            "default": "#E5C9C8",
            "divider": "#F5ECE9",
            "focused": "#116A5A"
        }
    },
    "typography": {
        "fonts": {
            "sans": "Inter, system-ui, sans-serif",
            "serif": "Georgia, serif",
            "mono": "Fira Code, monospace",
            "display": "Plus Jakarta Sans, Inter, sans-serif"
        },
        "scale": {
            "h1": {
                "size": "2.5rem",
                "weight": "800",
                "line_height": "1.2",
                "letter_spacing": "-0.02em"
            },
            "h2": {
                "size": "2rem",
                "weight": "700",
                "line_height": "1.25",
                "letter_spacing": "-0.01em"
            },
            "h3": {
                "size": "1.5rem",
                "weight": "600",
                "line_height": "1.3",
                "letter_spacing": "-0.01em"
            },
            "h4": {
                "size": "1.25rem",
                "weight": "600",
                "line_height": "1.4",
                "letter_spacing": "0"
            },
            "p_large": {
                "size": "1.125rem",
                "weight": "400",
                "line_height": "1.5",
                "letter_spacing": "0"
            },
            "p_default": {
                "size": "1rem",
                "weight": "400",
                "line_height": "1.5",
                "letter_spacing": "0"
            },
            "p_small": {
                "size": "0.875rem",
                "weight": "400",
                "line_height": "1.4",
                "letter_spacing": "0"
            }
        }
    },
    "layout": {
        "breakpoints": {
            "sm": "640px",
            "md": "768px",
            "lg": "1024px",
            "xl": "1280px"
        },
        "spacing": {
            "1": "4px",
            "2": "8px",
            "3": "12px",
            "4": "16px",
            "6": "24px",
            "8": "32px",
            "12": "48px",
            "16": "64px",
            "24": "96px",
            "32": "128px",
            "48": "192px",
            "64": "256px"
        },
        "grid": {
            "columns": 12,
            "default_gap": "1.5rem"
        },
        "container": {
            "max_width": "480px",
            "padding_x": "1rem"
        }
    },
    "effects": {
        "radius": {
            "none": "0px",
            "sm": "8px",
            "md": "16px",
            "lg": "24px",
            "xl": "32px",
            "full": "9999px"
        },
        "shadows": {
            "none": "none",
            "sm": "0 2px 8px rgba(17, 106, 90, 0.04)",
            "base": "0 4px 16px rgba(17, 106, 90, 0.06)",
            "md": "0 8px 24px rgba(17, 106, 90, 0.08)",
            "lg": "0 16px 32px rgba(17, 106, 90, 0.12)",
            "xl": "0 24px 48px rgba(17, 106, 90, 0.16)",
            "inner": "inset 0 2px 4px rgba(0, 0, 0, 0.06)"
        },
        "borders": {
            "width_default": "1px",
            "width_thick": "2px",
            "focus_ring": "2px solid #116A5A"
        },
        "transitions": {
            "default_duration": "200ms",
            "default_easing": "cubic-bezier(0.4, 0, 0.2, 1)"
        }
    },
    "components": {
        "button": {
            "solid": {
                "default": "background-color: #116A5A; color: #FFFFFF; border-radius: 9999px; padding: 12px 24px; font-weight: 600; transition: all 200ms ease-in-out;",
                "hover": "background-color: #0D5246; transform: translateY(-1px);",
                "active": "background-color: #0A3F36; transform: translateY(0);",
                "disabled": "background-color: #D9C3C0; color: #A8928F; cursor: not-allowed;"
            },
            "outline": {
                "default": "background-color: transparent; border: 1px solid #E5C9C8; color: #116A5A; border-radius: 9999px; padding: 12px 24px; font-weight: 600; transition: all 200ms ease-in-out;",
                "hover": "background-color: #F5ECE9; border-color: #116A5A;",
                "active": "background-color: #E5C9C8;",
                "disabled": "border-color: #F5ECE9; color: #A8928F; cursor: not-allowed;"
            },
            "ghost": {
                "default": "background-color: transparent; color: #116A5A; border-radius: 9999px; padding: 12px 24px; font-weight: 600; transition: all 200ms ease-in-out;",
                "hover": "background-color: #F5ECE9;",
                "active": "background-color: #E5C9C8;",
                "disabled": "color: #A8928F; cursor: not-allowed;"
            }
        },
        "input": {
            "default": "background-color: #FFFFFF; border: 1px solid #E5C9C8; color: #140F0F; border-radius: 24px; padding: 16px 20px; font-size: 1rem; transition: all 200ms ease-in-out; box-shadow: 0 4px 16px rgba(17, 106, 90, 0.04);",
            "hover": "border-color: #D9C3C0;",
            "focus": "border-color: #116A5A; outline: none; box-shadow: 0 0 0 3px rgba(17, 106, 90, 0.15);",
            "error": "border-color: #EF4444; box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);",
            "disabled": "background-color: #FAF6F5; color: #A8928F; border-color: #F5ECE9; cursor: not-allowed;"
        },
        "card": {
            "container": "background-color: #FFFFFF; border-radius: 32px; border: 1px solid #F5ECE9; box-shadow: 0 8px 24px rgba(17, 106, 90, 0.06); overflow: hidden;",
            "header_padding": "24px 24px 12px 24px",
            "body_padding": "12px 24px 24px 24px",
            "footer_padding": "12px 24px 24px 24px"
        },
        "badge": {
            "default": "background-color: #F5ECE9; color: #116A5A; font-weight: 600; font-size: 0.75rem; padding: 6px 12px; border-radius: 9999px; display: inline-flex; align-items: center;",
            "success": "background-color: #D1FAE5; color: #065F46; font-weight: 600; font-size: 0.75rem; padding: 6px 12px; border-radius: 9999px;",
            "warning": "background-color: #FEF3C7; color: #92400E; font-weight: 600; font-size: 0.75rem; padding: 6px 12px; border-radius: 9999px;",
            "error": "background-color: #FEE2E2; color: #991B1B; font-weight: 600; font-size: 0.75rem; padding: 6px 12px; border-radius: 9999px;",
            "info": "background-color: #DBEAFE; color: #1E40AF; font-weight: 600; font-size: 0.75rem; padding: 6px 12px; border-radius: 9999px;"
        },
        "navbar": {
            "container": "background-color: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid #F5ECE9; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50;",
            "link_default": "color: #5C4E4C; font-weight: 500; font-size: 0.9375rem; transition: color 200ms ease-in-out;",
            "link_active": "color: #116A5A; font-weight: 600;",
            "link_hover": "color: #116A5A;"
        }
    }
}